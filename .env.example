# Handoff environment variables (names + placeholders only — never commit real values).
#
# TWO different files, by where the value is consumed:
#   • CLIENT (VITE_-prefixed) → put in `.env`. Loaded by Vite into the browser bundle.
#   • SERVER (GitHub OAuth, etc.) → put in `.dev.vars` for local dev (gitignored).
#     The auth routes run in the Cloudflare worker; src/server.ts reads them from the
#     Cloudflare env binding, which in `vite dev` comes from `.dev.vars` (NOT `.env`).
#     On deploy, bind them as Worker secrets (see wrangler.jsonc).

# ── Client → .env (build-time, VITE_-prefixed, exposed to the browser) ──
VITE_N8N_WEBHOOK_URL=
VITE_ENABLE_DEMO_FALLBACK=

# ── GitHub OAuth (HOFF-P3-05) → .dev.vars for local dev (server-side, NEVER VITE_-prefixed) ──
# Register a GitHub OAuth App and set the Authorization callback URL to:
#   <your-origin>/api/auth/github/callback
# e.g. http://localhost:8080/api/auth/github/callback (dev — match your dev port)
#      https://<your-prod-domain>/api/auth/github/callback (prod)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional. HMAC key used to sign the session cookie. If unset, the app falls
# back to GITHUB_CLIENT_SECRET. Use a long random string (e.g. `openssl rand -hex 32`).
SESSION_SECRET=
